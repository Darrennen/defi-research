# ── Wallet (required for live trading) ────────────────────────────────────────
# Create a DEDICATED bot wallet — never use your main wallet here
PRIVATE_KEY=0xyour_bot_wallet_private_key_here
WALLET_ADDRESS=0xyour_bot_wallet_address_here

# ── Capital ────────────────────────────────────────────────────────────────────
BANKROLL=140

# ── Telegram Alerts (optional but strongly recommended) ───────────────────────
# 1. Create a bot: message @BotFather on Telegram → /newbot
# 2. Get your chat ID: message @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
