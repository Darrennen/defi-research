# Dune Analytics API — from dune.com/settings/api
DUNE_API_KEY=your_dune_api_key_here

# Slack App — from api.slack.com/apps > Your App > Basic Information > Signing Secret
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Upstash Redis — from console.upstash.com > Your Database > REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Polymarket Bot — page lock (generate SESSION_SECRET with: openssl rand -hex 32)
POLYMARKET_PASSWORD=choose_a_strong_password_here
POLYMARKET_SESSION_SECRET=generate_with_openssl_rand_hex_32

# Polymarket Bot — from your bot wallet + Polymarket CLOB API
# 1. Create a dedicated wallet (never use your main wallet)
# 2. Get API keys: connect to polymarket.com, then call POST https://clob.polymarket.com/auth/api-key
# 3. Set POLYMARKET_DRY_RUN=true for simulation, =false to go live
POLYMARKET_PRIVATE_KEY=0xyour_bot_wallet_private_key_here
POLYMARKET_API_KEY=your_clob_api_key_here
POLYMARKET_API_SECRET=your_clob_api_secret_here
POLYMARKET_API_PASSPHRASE=your_clob_api_passphrase_here
POLYMARKET_DRY_RUN=true
